<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Haitian Tube - Complete Admin System</title>
    
    <link rel="stylesheet" href="https://cdn.fluidplayer.com/v3/current/fluidplayer.min.css">
    <script src="https://cdn.fluidplayer.com/v3/current/fluidplayer.min.js"></script>
    <script src="https://widget.cloudinary.com/v2.0/global/all.js" type="text/javascript"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://www.gstatic.com/firebasejs/9.6.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.0/firebase-auth-compat.js"></script>
    <script src="https://npmcdn.com/parse/dist/parse.min.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0a0a;
            color: #fff;
            transition: all 0.3s;
        }
        :root {
            --primary: #ff0000;
            --primary-dark: #cc0000;
            --bg-card: #111;
            --border: #222;
        }
        body.light { --bg-card: #fff; --border: #e0e0e0; background: #f0f2f5; color: #1a1a1a; }
        
        .app { display: flex; min-height: 100vh; }
        .sidebar {
            width: 260px;
            background: var(--bg-card);
            border-right: 1px solid var(--border);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            z-index: 100;
        }
        .sidebar-header { padding: 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
        .sidebar-header i { color: var(--primary); font-size: 28px; }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 20px;
            color: #aaa;
            cursor: pointer;
            transition: all 0.2s;
        }
        .nav-item:hover, .nav-item.active { background: rgba(255,0,0,0.1); color: var(--primary); }
        .main-content { margin-left: 260px; flex: 1; padding: 20px 30px; }
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border);
        }
        .stat-card i { font-size: 32px; color: var(--primary); margin-bottom: 10px; }
        .stat-card h3 { font-size: 28px; }
        .section-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 500;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-danger { background: #dc2626; color: white; }
        .btn-warning { background: #f59e0b; color: white; }
        .btn-secondary { background: #333; color: white; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid var(--border); }
        .video-thumb { width: 80px; height: 45px; object-fit: cover; border-radius: 6px; }
        .status-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
        }
        .status-active { background: #10b981; color: white; }
        .status-banned { background: #dc2626; color: white; }
        .status-strike { background: #f59e0b; color: white; }
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        .modal-content {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 30px;
            width: 90%;
            max-width: 500px;
        }
        .modal-content input, .modal-content textarea, .modal-content select {
            width: 100%;
            padding: 12px;
            background: #222;
            border: none;
            border-radius: 8px;
            color: white;
            margin: 10px 0;
        }
        body.light .modal-content input { background: #e9ecef; color: #1a1a1a; }
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            padding: 12px 24px;
            border-radius: 8px;
            z-index: 2000;
            display: none;
        }
        .login-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0a0a0a, #1a0000);
        }
        .login-box {
            background: var(--bg-card);
            padding: 40px;
            border-radius: 20px;
            width: 400px;
            text-align: center;
            border: 1px solid var(--border);
        }
        .login-box input {
            width: 100%;
            padding: 14px;
            margin: 10px 0;
            background: #222;
            border: none;
            border-radius: 8px;
            color: white;
        }
        .toggle-link { color: var(--primary); cursor: pointer; margin-top: 15px; display: inline-block; }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); transition: transform 0.3s; }
            .sidebar.mobile-open { transform: translateX(0); }
            .main-content { margin-left: 0; }
        }
    </style>
</head>
<body>
<div id="appContainer"></div>

<script>
    // ==================== PARSE & FIREBASE INIT ====================
    Parse.initialize("v3G2yMDo6sYSlyIezaCOUV1vK6kQnRtLUvvrZnjC", "0G2VC0HfCDZRadQWZAxlB5KHgZQ9l5giTkDYZkWk");
    Parse.serverURL = "https://parseapi.back4app.com/";
    const firebaseConfig = { apiKey: "AIzaSyBsfheLc8i-CsRGJ9jkbGUhdTj3ZD3SLu8", authDomain: "haitiantube-2affb.firebaseapp.com", projectId: "haitiantube-2affb" };
    firebase.initializeApp(firebaseConfig);
    
    const CLOUD_NAME = "dqx9c4kc6", UPLOAD_PRESET = "xp4psfnn";
    let currentUser = null;
    let allVideos = [];
    let allUsers = [];
    let copyrightStrikes = [];
    let currentPage = "dashboard";
    let uploadedFileUrl = null;
    
    // Admin emails
    const adminEmails = ["admin@haitiantube.com", "moderator@haitiantube.com"];
    
    // ==================== REAL DATA LOADERS ====================
    async function loadRealVideos() {
        try {
            const Video = Parse.Object.extend("Video");
            const query = new Parse.Query(Video);
            query.descending("createdAt");
            query.limit(500);
            const results = await query.find();
            allVideos = results.map(v => ({
                id: v.id,
                title: v.get("title") || "Untitled",
                videoUrl: v.get("videoUrl") || "",
                thumbnailUrl: v.get("thumbnailUrl") || "https://picsum.photos/400/225",
                creatorName: v.get("creatorName") || "User",
                creatorId: v.get("creatorId") || "",
                isAdmin: v.get("isAdmin") || false,
                views: v.get("views") || 0,
                likes: v.get("likes") || 0,
                category: v.get("category") || "Entertainment",
                status: v.get("status") || "active",
                copyrightStrike: v.get("copyrightStrike") || false,
                createdAt: v.get("createdAt")
            }));
        } catch(e) { console.error(e); allVideos = []; }
    }
    
    async function loadRealUsers() {
        try {
            const User = Parse.Object.extend("_User");
            const query = new Parse.Query(User);
            const results = await query.find();
            allUsers = [];
            for(let u of results) {
                const email = u.get("email") || "";
                const userId = u.id;
                const userVideos = allVideos.filter(v => v.creatorId === userId);
                allUsers.push({
                    id: userId,
                    email: email,
                    username: u.get("username") || email.split('@')[0] || "User",
                    isAdmin: adminEmails.includes(email),
                    status: u.get("status") || "active",
                    strikes: u.get("copyrightStrikes") || 0,
                    isBanned: u.get("isBanned") || false,
                    videoCount: userVideos.length,
                    totalViews: userVideos.reduce((s,v)=>s+v.views,0)
                });
            }
        } catch(e) { console.error(e); allUsers = []; }
    }
    
    async function loadCopyrightStrikes() {
        try {
            const Strike = Parse.Object.extend("CopyrightStrike");
            const query = new Parse.Query(Strike);
            const results = await query.find();
            copyrightStrikes = results.map(s => ({
                id: s.id,
                videoId: s.get("videoId"),
                videoTitle: s.get("videoTitle"),
                creatorId: s.get("creatorId"),
                creatorName: s.get("creatorName"),
                reason: s.get("reason"),
                issuedBy: s.get("issuedBy"),
                createdAt: s.get("createdAt")
            }));
        } catch(e) { copyrightStrikes = []; }
    }
    
    // ==================== AUTH & LOGIN/REGISTER ====================
    async function signUp(email, password, username) {
        try {
            const userCred = await firebase.auth().createUserWithEmailAndPassword(email, password);
            await userCred.user.updateProfile({ displayName: username });
            // Create Parse user
            const user = new Parse.User();
            user.set("username", username);
            user.set("email", email);
            user.set("password", password);
            user.set("status", "active");
            user.set("copyrightStrikes", 0);
            user.set("isBanned", false);
            await user.signUp();
            showToast("Account created! Please login.");
            return true;
        } catch(e) { showToast(e.message); return false; }
    }
    
    async function signIn(email, password) {
        try {
            const userCred = await firebase.auth().signInWithEmailAndPassword(email, password);
            // Check if banned in Parse
            const query = new Parse.Query(Parse.User);
            query.equalTo("email", email);
            const parseUser = await query.first();
            if(parseUser && parseUser.get("isBanned")) {
                await firebase.auth().signOut();
                showToast("Account is banned. Contact admin.");
                return false;
            }
            currentUser = userCred.user;
            showToast("Login successful!");
            await loadRealVideos();
            await loadRealUsers();
            await loadCopyrightStrikes();
            renderAdminPanel();
            return true;
        } catch(e) { showToast("Invalid credentials"); return false; }
    }
    
    async function signOut() {
        await firebase.auth().signOut();
        currentUser = null;
        showToast("Logged out");
        renderAuthScreen();
    }
    
    // ==================== ADMIN FUNCTIONS ====================
    async function banUser(userId, permanent = false) {
        try {
            const User = Parse.Object.extend("_User");
            const query = new Parse.Query(User);
            const userObj = await query.get(userId);
            userObj.set("isBanned", true);
            userObj.set("status", "banned");
            await userObj.save();
            // Also ban all user videos
            const Video = Parse.Object.extend("Video");
            const vidQuery = new Parse.Query(Video);
            vidQuery.equalTo("creatorId", userId);
            const userVideos = await vidQuery.find();
            for(let v of userVideos) {
                v.set("status", "banned");
                await v.save();
            }
            showToast("User banned permanently");
            await loadRealUsers();
            await loadRealVideos();
            renderCurrentPage();
        } catch(e) { showToast("Ban failed"); }
    }
    
    async function unbanUser(userId) {
        try {
            const User = Parse.Object.extend("_User");
            const query = new Parse.Query(User);
            const userObj = await query.get(userId);
            userObj.set("isBanned", false);
            userObj.set("status", "active");
            await userObj.save();
            const Video = Parse.Object.extend("Video");
            const vidQuery = new Parse.Query(Video);
            vidQuery.equalTo("creatorId", userId);
            const userVideos = await vidQuery.find();
            for(let v of userVideos) {
                v.set("status", "active");
                await v.save();
            }
            showToast("User unbanned");
            await loadRealUsers();
            await loadRealVideos();
            renderCurrentPage();
        } catch(e) { showToast("Unban failed"); }
    }
    
    async function issueCopyrightStrike(videoId, videoTitle, creatorId, creatorName, reason) {
        if(!currentUser) return;
        try {
            const Strike = Parse.Object.extend("CopyrightStrike");
            const strike = new Strike();
            strike.set("videoId", videoId);
            strike.set("videoTitle", videoTitle);
            strike.set("creatorId", creatorId);
            strike.set("creatorName", creatorName);
            strike.set("reason", reason);
            strike.set("issuedBy", currentUser.email);
            await strike.save();
            
            // Update video with strike
            const Video = Parse.Object.extend("Video");
            const vidQuery = new Parse.Query(Video);
            const video = await vidQuery.get(videoId);
            video.set("copyrightStrike", true);
            video.set("status", "strike");
            await video.save();
            
            // Increase user strike count
            const User = Parse.Object.extend("_User");
            const userQuery = new Parse.Query(User);
            const user = await userQuery.get(creatorId);
            let strikes = user.get("copyrightStrikes") || 0;
            strikes++;
            user.set("copyrightStrikes", strikes);
            if(strikes >= 3) {
                user.set("isBanned", true);
                user.set("status", "banned");
                showToast("3 strikes! User automatically banned.");
            }
            await user.save();
            
            showToast(`Copyright strike issued to ${creatorName}`);
            await loadCopyrightStrikes();
            await loadRealUsers();
            await loadRealVideos();
            renderCurrentPage();
        } catch(e) { showToast("Strike failed: " + e.message); }
    }
    
    async function deleteVideoById(videoId) {
        if(!confirm("Delete this video permanently?")) return;
        try {
            const Video = Parse.Object.extend("Video");
            const query = new Parse.Query(Video);
            const video = await query.get(videoId);
            await video.destroy();
            showToast("Video deleted");
            await loadRealVideos();
            await loadRealUsers();
            renderCurrentPage();
        } catch(e) { showToast("Error deleting"); }
    }
    
    // ==================== UI RENDERING ====================
    function formatNumber(num) { if (num >= 1000000) return (num/1000000).toFixed(1)+'M'; if (num >= 1000) return (num/1000).toFixed(1)+'K'; return num.toString(); }
    function showToast(msg) { const t = document.getElementById('toast'); if(t) { t.textContent = msg; t.style.display = 'block'; setTimeout(() => t.style.display = 'none', 2000); } }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    
    function renderAuthScreen() {
        document.getElementById('appContainer').innerHTML = `
            <div class="login-container">
                <div class="login-box">
                    <i class="fas fa-play-circle" style="font-size: 48px; color: #ff0000;"></i>
                    <h2 style="margin: 20px 0;">Haitian Tube</h2>
                    <div id="authToggle">
                        <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                            <button class="btn btn-primary" id="showLoginBtn" style="flex:1">Login</button>
                            <button class="btn btn-secondary" id="showSignupBtn" style="flex:1">Sign Up</button>
                        </div>
                        <div id="loginForm">
                            <input type="email" id="loginEmail" placeholder="Email" autocomplete="email">
                            <input type="password" id="loginPassword" placeholder="Password">
                            <button class="btn btn-primary" id="doLoginBtn" style="width:100%; margin-top:15px;">Login</button>
                        </div>
                        <div id="signupForm" style="display:none;">
                            <input type="text" id="signupName" placeholder="Username">
                            <input type="email" id="signupEmail" placeholder="Email">
                            <input type="password" id="signupPassword" placeholder="Password">
                            <button class="btn btn-primary" id="doSignupBtn" style="width:100%; margin-top:15px;">Create Account</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="toast" id="toast"></div>
        `;
        
        document.getElementById('showLoginBtn').onclick = () => {
            document.getElementById('loginForm').style.display = 'block';
            document.getElementById('signupForm').style.display = 'none';
        };
        document.getElementById('showSignupBtn').onclick = () => {
            document.getElementById('loginForm').style.display = 'none';
            document.getElementById('signupForm').style.display = 'block';
        };
        document.getElementById('doLoginBtn').onclick = async () => {
            const email = document.getElementById('loginEmail').value;
            const pass = document.getElementById('loginPassword').value;
            await signIn(email, pass);
        };
        document.getElementById('doSignupBtn').onclick = async () => {
            const name = document.getElementById('signupName').value;
            const email = document.getElementById('signupEmail').value;
            const pass = document.getElementById('signupPassword').value;
            if(await signUp(email, pass, name)) {
                document.getElementById('showLoginBtn').click();
            }
        };
    }
    
    function renderAdminPanel() {
        document.getElementById('appContainer').innerHTML = `
            <div class="app">
                <div class="sidebar" id="sidebar">
                    <div class="sidebar-header"><i class="fas fa-play-circle"></i><h2>Haitian Tube<br><span style="font-size:12px;">Admin Console</span></h2></div>
                    <div class="nav-item active" data-page="dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</div>
                    <div class="nav-item" data-page="videos"><i class="fas fa-video"></i> Videos</div>
                    <div class="nav-item" data-page="upload"><i class="fas fa-upload"></i> Upload</div>
                    <div class="nav-item" data-page="users"><i class="fas fa-users"></i> Users & Creators</div>
                    <div class="nav-item" data-page="strikes"><i class="fas fa-gavel"></i> Copyright Strikes</div>
                    <div class="nav-item" data-page="settings"><i class="fas fa-cog"></i> Settings</div>
                    <div style="margin-top:20px; border-top:1px solid #222; padding-top:20px;">
                        <div class="nav-item" id="logoutBtn"><i class="fas fa-sign-out-alt"></i> Logout</div>
                    </div>
                </div>
                <div class="main-content">
                    <div class="top-bar">
                        <div><i class="fas fa-bars" id="menuToggle" style="cursor:pointer; font-size:24px; display:none;"></i></div>
                        <div class="user-info" style="display:flex; align-items:center; gap:15px;">
                            <span id="adminNameDisplay">${currentUser?.displayName || 'Admin'}</span>
                            <i class="fas fa-check-circle" style="color:#1DA1F2;"></i>
                            <div class="user-avatar" style="width:40px;height:40px;border-radius:50%;background:#ff0000;display:flex;align-items:center;justify-content:center;"><i class="fas fa-user-shield"></i></div>
                        </div>
                    </div>
                    <div id="pageContent"></div>
                </div>
            </div>
            <div class="toast" id="toast"></div>
            <div class="modal" id="strikeModal"><div class="modal-content"><h2>Issue Copyright Strike</h2><div id="strikeVideoInfo"></div><textarea id="strikeReason" placeholder="Reason for strike" rows="3"></textarea><button class="btn btn-primary" id="confirmStrikeBtn">Issue Strike</button><button class="btn btn-secondary" onclick="closeModal('strikeModal')">Cancel</button></div></div>
        `;
        attachNavEvents();
        renderCurrentPage();
        if(window.innerWidth <= 768) document.getElementById('menuToggle').style.display = 'block';
        document.getElementById('logoutBtn').onclick = signOut;
    }
    
    let currentStrikeVideo = null;
    window.openStrikeModal = (video) => {
        currentStrikeVideo = video;
        document.getElementById('strikeVideoInfo').innerHTML = `<p><strong>Video:</strong> ${video.title}</p><p><strong>Creator:</strong> ${video.creatorName}</p>`;
        document.getElementById('strikeModal').style.display = 'flex';
        document.getElementById('confirmStrikeBtn').onclick = async () => {
            const reason = document.getElementById('strikeReason').value;
            if(!reason) { showToast("Enter reason"); return; }
            await issueCopyrightStrike(video.id, video.title, video.creatorId, video.creatorName, reason);
            closeModal('strikeModal');
            document.getElementById('strikeReason').value = '';
        };
    };
    
    function renderDashboard() {
        const activeVideos = allVideos.filter(v => v.status === "active").length;
        const totalViews = allVideos.reduce((s,v)=>s+v.views,0);
        const bannedUsers = allUsers.filter(u => u.isBanned).length;
        const totalStrikes = copyrightStrikes.length;
        return `
            <h2>📊 Admin Dashboard</h2>
            <div class="stats-grid">
                <div class="stat-card"><i class="fas fa-video"></i><h3>${activeVideos}</h3><p>Active Videos</p></div>
                <div class="stat-card"><i class="fas fa-eye"></i><h3>${formatNumber(totalViews)}</h3><p>Total Views</p></div>
                <div class="stat-card"><i class="fas fa-ban"></i><h3>${bannedUsers}</h3><p>Banned Users</p></div>
                <div class="stat-card"><i class="fas fa-gavel"></i><h3>${totalStrikes}</h3><p>Copyright Strikes</p></div>
            </div>
            <div class="section-card"><h3>Recent Copyright Strikes</h3><div id="recentStrikes"></div></div>
            <div class="section-card"><h3>Quick Actions</h3><div style="display:flex; gap:10px; flex-wrap:wrap;"><button class="btn btn-primary" onclick="document.querySelector('[data-page=upload]').click()">Upload Video</button><button class="btn btn-danger" onclick="document.querySelector('[data-page=users]').click()">Manage Users</button></div></div>
        `;
    }
    
    function renderVideosPage() {
        return `<h2>Video Management</h2><div class="section-card"><input type="text" id="videoSearch" placeholder="Search..." style="width:100%;padding:10px;margin-bottom:20px;"><div id="videosList"></div></div>`;
    }
    
    function renderVideosTable(search="") {
        const filtered = allVideos.filter(v => v.title.toLowerCase().includes(search.toLowerCase()));
        const container = document.getElementById('videosList');
        if(!container) return;
        container.innerHTML = `<table><thead><tr><th>Thumb</th><th>Title</th><th>Creator</th><th>Views</th><th>Status</th><th>Actions</th></tr></thead><tbody>
            ${filtered.map(v => `<tr>
                <td><img src="${v.thumbnailUrl}" class="video-thumb"></td>
                <td>${v.title.substring(0,40)}</td>
                <td>${v.creatorName}</td>
                <td>${formatNumber(v.views)}</td>
                <td><span class="status-badge ${v.status==='active'?'status-active':v.status==='strike'?'status-strike':'status-banned'}">${v.status}</span></td>
                <td><button class="btn btn-warning btn-sm" onclick="openStrikeModal(${JSON.stringify(v).replace(/"/g, '&quot;')})"><i class="fas fa-gavel"></i> Strike</button> <button class="btn btn-danger btn-sm" onclick="deleteVideoById('${v.id}')"><i class="fas fa-trash"></i> Delete</button></td>
            </tr>`).join('')}
        </tbody></table>`;
    }
    
    function renderUsersPage() {
        return `<h2>User & Creator Management</h2><div class="section-card"><input type="text" id="userSearch" placeholder="Search users..." style="width:100%;padding:10px;margin-bottom:20px;"><div id="usersList"></div></div>`;
    }
    
    function renderUsersTable(search="") {
        const filtered = allUsers.filter(u => u.username.toLowerCase().includes(search.toLowerCase()) || u.email.toLowerCase().includes(search.toLowerCase()));
        const container = document.getElementById('usersList');
        if(!container) return;
        container.innerHTML = `<table><thead><tr><th>Username</th><th>Email</th><th>Videos</th><th>Strikes</th><th>Status</th><th>Actions</th></tr></thead><tbody>
            ${filtered.map(u => `<tr>
                <td>${u.username} ${u.isAdmin ? '👑' : ''}</td>
                <td>${u.email}</td>
                <td>${u.videoCount}</td>
                <td>${u.strikes || 0}/3</td>
                <td><span class="status-badge ${u.isBanned ? 'status-banned' : 'status-active'}">${u.isBanned ? 'Banned' : 'Active'}</span></td>
                <td>${!u.isAdmin ? (u.isBanned ? `<button class="btn btn-primary btn-sm" onclick="unbanUser('${u.id}')">Unban</button>` : `<button class="btn btn-danger btn-sm" onclick="banUser('${u.id}')">Ban User</button>`) : 'Admin'}</td>
            </tr>`).join('')}
        </tbody></table>`;
    }
    
    function renderStrikesPage() {
        return `<h2><i class="fas fa-gavel"></i> Copyright Strike Management</h2>
        <div class="section-card"><h3>All Issued Strikes</h3><div id="strikesList"></div></div>
        <div class="section-card"><h3>Strike Policy</h3><p>3 strikes = automatic permanent ban. Admins can issue strikes for copyright violations.</p></div>`;
    }
    
    function renderStrikesTable() {
        const container = document.getElementById('strikesList');
        if(!container) return;
        container.innerHTML = `<table><thead><tr><th>Video</th><th>Creator</th><th>Reason</th><th>Issued By</th><th>Date</th></tr></thead><tbody>
            ${copyrightStrikes.map(s => `<tr><td>${s.videoTitle}</td><td>${s.creatorName}</td><td>${s.reason}</td><td>${s.issuedBy}</td><td>${new Date(s.createdAt).toLocaleDateString()}</td></tr>`).join('')}
        </tbody></table>`;
    }
    
    function renderSettingsPage() {
        return `<h2>Admin Settings</h2><div class="section-card"><h3>Platform Rules</h3><p>Copyright strikes are issued for unauthorized content. Users with 3 strikes are automatically banned.</p><hr><h3>Admins</h3><p>${adminEmails.join(', ')}</p><button class="btn btn-secondary" onclick="localStorage.clear();showToast('Cache cleared')">Clear Local Cache</button></div>`;
    }
    
    function renderCurrentPage() {
        const container = document.getElementById('pageContent');
        if(!container) return;
        if(currentPage === 'dashboard') container.innerHTML = renderDashboard();
        else if(currentPage === 'videos') container.innerHTML = renderVideosPage();
        else if(currentPage === 'users') container.innerHTML = renderUsersPage();
        else if(currentPage === 'strikes') container.innerHTML = renderStrikesPage();
        else if(currentPage === 'settings') container.innerHTML = renderSettingsPage();
        else if(currentPage === 'upload') { openUploadModal(); return; }
        
        if(currentPage === 'videos') { renderVideosTable(); document.getElementById('videoSearch')?.addEventListener('input', e => renderVideosTable(e.target.value)); }
        if(currentPage === 'users') { renderUsersTable(); document.getElementById('userSearch')?.addEventListener('input', e => renderUsersTable(e.target.value)); }
        if(currentPage === 'strikes') renderStrikesTable();
        if(currentPage === 'dashboard') {
            const recentDiv = document.getElementById('recentStrikes');
            if(recentDiv) recentDiv.innerHTML = copyrightStrikes.slice(0,5).map(s => `<div>🔨 ${s.videoTitle} - ${s.creatorName} (${s.reason.substring(0,50)})</div>`).join('') || '<div>No strikes yet</div>';
        }
    }
    
    function attachNavEvents() {
        document.querySelectorAll('.nav-item').forEach(item => {
            item.onclick = () => {
                const page = item.dataset.page;
                if(page) { currentPage = page; renderCurrentPage(); }
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                item.classList.add('active');
                if(window.innerWidth <= 768) document.getElementById('sidebar').classList.remove('mobile-open');
            };
        });
        document.getElementById('menuToggle').onclick = () => document.getElementById('sidebar').classList.toggle('mobile-open');
    }
    
    // Upload functions
    function openUploadModal() {
        const modalHtml = `<div class="modal" id="uploadModal" style="display:flex"><div class="modal-content"><h2>Upload Video</h2><div id="cloudinaryUploadBtn" style="background:#222;border:2px dashed var(--primary);border-radius:12px;padding:30px;text-align:center;cursor:pointer;"><i class="fas fa-cloud-upload-alt" style="font-size:48px;"></i><p>Click to select video</p></div><input type="text" id="adminVideoTitle" placeholder="Title"><textarea id="adminVideoDesc" placeholder="Description"></textarea><select id="adminVideoCategory"><option>Entertainment</option><option>Music</option></select><div style="display:flex;gap:12px;margin-top:20px;"><button class="btn btn-secondary" onclick="closeModal('uploadModal')">Cancel</button><button class="btn btn-primary" id="confirmUploadBtn" disabled>Upload</button></div></div></div>`;
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        initCloudinaryUpload();
        document.getElementById('confirmUploadBtn').onclick = async () => {
            if(!uploadedFileUrl) { showToast("Upload video first"); return; }
            const title = document.getElementById('adminVideoTitle').value.trim();
            if(!title) { showToast("Enter title"); return; }
            const Video = Parse.Object.extend("Video");
            const newVideo = new Video();
            newVideo.set("title", title);
            newVideo.set("videoUrl", uploadedFileUrl);
            newVideo.set("thumbnailUrl", uploadedFileUrl.replace(/\.[^/.]+$/, '.jpg') || "https://picsum.photos/400/225");
            newVideo.set("creatorId", currentUser.uid);
            newVideo.set("creatorName", currentUser.displayName || "Admin");
            newVideo.set("isAdmin", true);
            newVideo.set("views", 0);
            newVideo.set("status", "active");
            newVideo.set("category", document.getElementById('adminVideoCategory').value);
            await newVideo.save();
            showToast("Video uploaded!");
            closeModal('uploadModal');
            await loadRealVideos();
            renderCurrentPage();
            document.getElementById('uploadModal')?.remove();
        };
    }
    
    function initCloudinaryUpload() {
        const btn = document.getElementById('cloudinaryUploadBtn');
        if(!btn) return;
        btn.onclick = () => {
            const widget = cloudinary.createUploadWidget({ cloudName: CLOUD_NAME, uploadPreset: UPLOAD_PRESET, sources: ['local'], resourceType: 'video' }, (error, result) => {
                if(result?.event === "success") {
                    uploadedFileUrl = result.info.secure_url;
                    document.getElementById('confirmUploadBtn').disabled = false;
                    showToast("Video ready!");
                }
            });
            widget.open();
        };
    }
    
    window.closeModal = closeModal;
    window.deleteVideoById = deleteVideoById;
    window.banUser = banUser;
    window.unbanUser = unbanUser;
    window.openStrikeModal = openStrikeModal;
    
    // Start
    firebase.auth().onAuthStateChanged(async (user) => {
        if(user && adminEmails.includes(user.email)) {
            currentUser = user;
            await loadRealVideos();
            await loadRealUsers();
            await loadCopyrightStrikes();
            renderAdminPanel();
        } else if(user) {
            showToast("Admin access only. This account is not authorized.");
            await firebase.auth().signOut();
            renderAuthScreen();
        } else {
            renderAuthScreen();
        }
    });
</script>
</body>
</html>
